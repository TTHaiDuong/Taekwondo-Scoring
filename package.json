{
  "name": "scoreboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,server,open,caddy -c magenta,blue,cyan,yellow \"npm run dev:next\" \"npm run dev:server\" \"npm run dev:open\" \"npm run dev:caddy\"",
    "dev:no-watch": "concurrently -n next,server,open,caddy -c magenta,blue,cyan,yellow \"npm run dev:next\" \"npm run dev:server:no-watch\" \"npm run dev:open\" \"npm run dev:caddy\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:open": "wait-on http://localhost:3000/share && npx open-cli --app edge http://localhost:3000/share",
    "dev:server": "node --watch --import tsx/esm ./src/server/server.ts",
    "dev:server:no-watch": "node --import tsx/esm ./src/server/server.ts",
    "dev:next": "npx next dev --hostname 0.0.0.0 --port 3000 --turbopack",
    "dev:caddy": "node --import tsx/esm ./start.ts",
    "dev:https": "concurrently -n next,server -c magenta,blue \"next dev --turbopack --experimental-https\" \"npm run dev:server\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "default-gateway": "^7.2.2",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "framer-motion": "^12.42.0",
    "hls.js": "^1.5.17",
    "ip": "^2.0.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-client": "^2.20.0",
    "livekit-server-sdk": "^2.15.5",
    "next": "15.1.5",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.43.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-code": "^2.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swiper": "^12.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@svgr/webpack": "^8.1.0",
    "@types/cors": "^2.8.19",
    "@types/default-gateway": "^7.2.2",
    "@types/express": "^5.0.6",
    "@types/ip": "^1.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.1.5",
    "nodemon": "^3.1.7",
    "open-cli": "^8.0.0",
    "postcss": "^8",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "type": "module"
}